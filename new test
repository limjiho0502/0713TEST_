<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>열섬현상과 전력수요의 관계 분석</title>
    <!-- Chart.js 라이브러리 및 추세선 플러그인 로드 -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary-blue: #1e3a8a;
            --secondary-blue: #3b82f6;
            --primary-orange: #ea580c;
            --secondary-orange: #f97316;
            --bg-gray: #f8fafc;
            --text-dark: #0f172a;
            --text-light: #64748b;
            --card-bg: #ffffff;
            --error-bg: #fef2f2;
            --error-border: #f87171;
            --error-text: #991b1b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: var(--bg-gray);
            color: var(--text-dark);
            line-height: 1.6;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* 헤더 스타일 */
        header {
            text-align: center;
            padding: 40px 20px;
            background: linear-gradient(135deg, var(--primary-blue), #0f172a);
            color: #ffffff;
            border-radius: 20px;
            margin-bottom: 25px;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }

        header h1 {
            font-size: 2.2rem;
            margin-bottom: 12px;
            font-weight: 800;
        }

        header p {
            font-size: 1.2rem;
            color: #93c5fd;
            font-weight: 500;
        }

        /* 둥근 카드 형태 구분 */
        .card {
            background-color: var(--card-bg);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 25px;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);
            border: 1px solid #e2e8f0;
        }

        .card h2 {
            font-size: 1.4rem;
            color: var(--primary-blue);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 10px;
        }

        p.description {
            color: var(--text-light);
            font-size: 0.95rem;
            margin-bottom: 20px;
        }

        /* 필터 구조 */
        .filter-container {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            background-color: #f1f5f9;
            padding: 15px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .filter-item {
            display: flex;
