        /* 에러 알림판 */
        .error-panel {
            display: none;
            background-color: var(--error-bg);
            border: 2px solid var(--error-border);
            color: var(--error-text);
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 25px;
        }

        .error-panel h3 {
