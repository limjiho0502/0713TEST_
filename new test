            font-weight: 600;
        }

        .stat-box .value {
            font-size: 1.5rem;
            font-weight: 700;
            margin-top: 5px;
        }

        .stat-box.blue .value { color: var(--secondary-blue); }
        .stat-box.orange .value { color: var(--primary-orange); }

        /* 그래프 영역 레이아웃 */
        .chart-wrapper {
            position: relative;
            width: 100%;
            height: 450px;
            margin-top: 15px;
        }

        /* 분석 결과 데코레이션 */
        .analysis-box {
            background-color: #eff6ff;
            border-left: 4px solid var(--secondary-blue);
            padding: 20px;
            border-radius: 0 12px 12px 0;
            margin-top: 20px;
        }

        .analysis-box h4 {
            font-size: 1.05rem;
            color: var(--primary-blue);
            margin-bottom: 8px;
        }

        .notice-text {
            font-size: 0.85rem;
            color: var(--text-light);
            margin-top: 12px;
            display: block;
            font-style: italic;
        }

        .result-summary {
            font-size: 1rem;
            color: var(--text-dark);
            line-height: 1.7;
        }

        /* 반응형 모바일 대응 */
        @media (max-width: 768px) {
            body { padding: 10px; }
            header { padding: 30px 15px; }
            header h1 { font-size: 1.6rem; }
            header p { font-size: 1rem; }
            .card { padding: 20px; }
            .chart-wrapper { height: 320px; }
        }
    </style>
</head>
<body>

<div class="container">
    <!-- 1. 제목과 탐구 질문 -->
    <header>
        <h1>열섬현상과 전력수요의 관계</h1>
        <p>📊 탐구 질문: 열섬 강도가 커질수록 전력수요도 증가할까?</p>
    </header>

    <!-- 예외 처리 오류 메시지 영역 -->
    <div id="error-alert" class="error-panel">
        <h3>⚠️ 데이터를 불러오는 도중 오류가 발생했습니다.</h3>
        <p>아래 원인과 해결 방법을 확인해 주세요:</p>
        <ul>
            <li><strong>파일 위치 확인:</strong> <code>index.html</code>과 동일한 디렉토리에 <code>서울_기온.csv</code>, <code>양평_기온.csv</code>, <code>전력수요.csv</code> 파일이 모두 존재하는지 확인하세요.</li>
            <li><strong>로컬 보안 정책(CORS):</strong> 브라우저에서 HTML 파일을 더블 클릭으로 직접 열면 보안 상의 이유로 내부 CSV 파일을 읽지 못합니다. VS Code의 <strong>Live Server</strong> 확장을 실행하거나 <strong>GitHub Pages</strong>에 업로드하여 주소(HTTP/HTTPS) 형태로 접근해 주세요.</li>
        </ul>
    </div>

    <!-- 2. 데이터 확인 및 필터 -->
    <div class="card">
        <h2>📂 2. 데이터 확인 및 기간 안내</h2>
        <p class="description">
            본 분석은 <strong>2025년 1년 동안 관측된 시간별 데이터</strong>를 활용합니다. 도심인 <strong>서울</strong>과 근교 전원 지역인 <strong>양평</strong>의 기온차를 분석하여 인공 열섬현상과 대도시 전력수요(MWh) 간 추이를 비교합니다.
        </p>
        
        <div class="filter-container">
            <div class="filter-item">
                <label for="month-filter">📆 데이터 기간 조회 (월별 리드)</label>
                <select id="month-filter">
                    <option value="all">1년 전체 보기</option>
                    <option value="1">1월 (겨울철 피크)</option>
                    <option value="5">5월 (봄철 대기)</option>
                    <option value="8">8월 (여름철 폭염 피크)</option>
                    <option value="10">10월 (가을철 대기)</option>
                </select>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-box">
                <div class="label">동시 관측 데이터 타임라인</div>
                <div id="stat-count" class="value">-</div>
            </div>
            <div class="stat-box blue">
                <div class="label">평균 열섬 강도</div>
                <div id="stat-uhi" class="value">-</div>
            </div>
            <div class="stat-box orange">
                <div class="label">평균 전력수요</div>
                <div id="stat-power" class="value">-</div>
            </div>
        </div>
    </div>

    <!-- 3. 열섬현상 분석 -->
    <div class="card">
        <h2>🔥 3. 도심·교외 기온 및 열섬 강도 분석</h2>
        <p class="description">같은 날짜 및 시각의 도심 기온(서울)과 교외 기온(양평)을 비교합니다. <strong>열섬 강도는 '서울 기온 - 양평 기온'</strong>으로 계산됩니다.</p>
        <div class="chart-wrapper">
            <canvas id="tempChart"></canvas>
        </div>
    </div>

    <!-- 4. 전력수요 분석 -->
    <div class="card">
        <h2>⚡ 4. 시간 흐름에 따른 전력수요 변동</h2>
        <p class="description">선택한 시기별 전력수요(MWh)의 변화 추세를 나타냅니다. 기온이 과도하게 높은 여름철 피크 시기나 한파가 불어닥친 겨울철 전력수요 급증 시점을 교차 확인해 볼 수 있습니다.</p>
        <div class="chart-wrapper">
            <canvas id="powerChart"></canvas>
        </div>
    </div>

    <!-- 5. 상관관계 분석 -->
    <div class="card">
        <h2>📈 5. 열섬 강도와 전력수요의 상관관계 분석</h2>
        <p class="description">열섬 강도를 X축, 전력수요를 Y축으로 매핑한 데이터 산점도 분포와 수학적 선형 추세선 구조를 연동합니다.</p>
        <div class="chart-wrapper">
            <canvas id="scatterChart"></canvas>
        </div>
        
        <div class="analysis-box">
            <h4>📊 통계 해석 레이더</h4>
            <p style="font-weight: 700; margin-bottom: 5px;">피어슨 상관계수 (r): <span id="r-value" style="color:var(--primary-orange); font-size:1.1rem;">-</span></p>
            <p>상관계수 기반 분석 결과: <strong id="r-interpretation" style="color:var(--primary-blue);">-</strong></p>
            <span class="notice-text">※ 안내: 두 지표 간 통계적 상관관계가 산출된다고 하여 이것이 곧장 직접적인 인과관계(원인과 결과)를 완벽히 입증하는 것은 아닙니다. 계절의 변화(외부 기온 환경 요인)가 두 요소를 동시에 자극하여 발생하는 허위 상관성 유무 등을 고려하여 가공되어야 합니다.</span>
        </div>
    </div>

    <!-- 6. 탐구 결과 -->
    <div class="card" style="background-color: #fffbeb; border: 1px solid #fef3c7;">
        <h2>📝 6. 탐구 결과 최종 요약</h2>
        <div id="summary-panel" class="result-summary">
            데이터 수집 분석을 정상 진행하고 있습니다...
        </div>
    </div>
</div>

<script>
    // 전역 변수 설정
    let allData = [];
    let charts = {};

    // 한글(CP949/EUC-KR) 인코딩 호환용 파일 수신 및 데이터 파서 구현
    async function loadCSV(filename) {
        const response = await fetch(filename);
        if (!response.ok) {
            throw new Error(`파일 수신 실패: ${filename}`);
        }
        const buffer = await response.arrayBuffer();
        const decoder = new TextDecoder('euc-kr'); // CP949 호환 파싱 코드 기입
        const text = decoder.decode(buffer);
        
        const lines = text.split(/\r?\n/);
        if (lines.length === 0 || lines[0] === "") return [];

        const headers = lines[0].split(',').map(h => h.trim());
        const dataRows = [];

        for (let i = 1; i < lines.length; i++) {
            if (!lines[i].trim()) continue;
            const currentLine = lines[i].split(',');
            const rowObj = {};
            headers.forEach((header, index) => {
                rowObj[header] = currentLine[index] ? currentLine[index].trim() : null;
            });
            dataRows.push(rowObj);
        }
        return dataRows;
    }

    // 통계적 피어슨 상관계수(r) 구문 알고리즘
    function calculatePearson(x, y) {
        const n = x.length;
        if (n === 0) return 0;
        const sumX = x.reduce((a, b) => a + b, 0);
        const sumY = y.reduce((a, b) => a + b, 0);
        const sumXY = x.reduce((sum, xi, i) => sum + xi * y[i], 0);
        const sumX2 = x.reduce((sum, xi) => sum + xi * xi, 0);
        const sumY2 = y.reduce((sum, yi) => sum + yi * yi, 0);

        const num = (n * sumXY) - (sumX * sumY);
        const den = Math.sqrt(((n * sumX2) - (sumX * sumX)) * ((n * sumY2) - (sumY * sumY)));
        return den === 0 ? 0 : num / den;
    }

    // 선형 최소제곱법 추세선 좌표 정보 산출 함수
    function getTrendLinePoints(x, y) {
        const n = x.length;
        if (n === 0) return [];
        const sumX = x.reduce((a, b) => a + b, 0);
        const sumY = y.reduce((a, b) => a + b, 0);
        const sumXY = x.reduce((sum, xi, i) => sum + xi * y[i], 0);
        const sumX2 = x.reduce((sum, xi) => sum + xi * xi, 0);

        const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
        const intercept = (sumY - slope * sumX) / n;

        const minX = Math.min(...x);
        const maxX = Math.max(...x);

        return [
            { x: minX, y: slope * minX + intercept },
            { x: maxX, y: slope * maxX + intercept }
        ];
    }

    // 애플리케이션 초기화 구동부
    async function initApp() {
        try {
            // 정해진 로컬 디렉토리 내부 3개 동시 파싱 진행
            const [seoulTempRaw, yangpyeongTempRaw, powerDemandRaw] = await Promise.all([
                loadCSV('서울_기온.csv'),
                loadCSV('양평_기온.csv'),
                loadCSV('전력수요.csv')
            ]);

            // 탐색 속도 향상을 위한 키-값 해시 맵 구현
            const ypMap = new Map();
            yangpyeongTempRaw.forEach(item => {
                if (item['일시'] && item['기온(°C)']) ypMap.set(item['일시'], parseFloat(item['기온(°C)']));
            });

            const pMap = new Map();
            powerDemandRaw.forEach(item => {
                if (item['일시'] && item['전력수요(MWh)']) pMap.set(item['일시'], parseFloat(item['전력수요(MWh)']));
            });

            // 내부 조인(Inner Join) 형태로 데이터 가공 동기화 통합
            seoulTempRaw.forEach(sItem => {
                const timeKey = sItem['일시'];
                if (ypMap.has(timeKey) && pMap.has(timeKey)) {
                    const sTemp = parseFloat(sItem['기온(°C)']);
                    const yTemp = ypMap.get(timeKey);
                    const power = pMap.get(timeKey);

                    if (!isNaN(sTemp) && !isNaN(yTemp) && !isNaN(power)) {
                        const dateParsed = new Date(timeKey);
                        allData.push({
                            datetime: timeKey,
                            month: dateParsed.getMonth() + 1,
                            seoulTemp: sTemp,
                            ypTemp: yTemp,
                            uhi: sTemp - yTemp, // 열섬 강도 정의 수식 연동
                            powerDemand: power
                        });
                    }
                }
            });

            if(allData.length === 0) {
                throw new Error("결합 대상 데이터 행이 존재하지 않습니다.");
            }

            // 첫 가동을 위한 연계 컨트롤 바인딩 및 기본 분석 실행
            document.getElementById('month-filter').addEventListener('change', runAnalysis);
            runAnalysis();

        } catch (err) {
            console.error(err);
            document.getElementById('error-alert').style.display = 'block';
        }
    }

    // 메인 분석 및 실시간 렌더링 구동 프로세스
    function runAnalysis() {
        const filterValue = document.getElementById('month-filter').value;
        
        // 필터 동작 처리
        const filteredData = filterValue === 'all' 
            ? allData 
            : allData.filter(d => d.month === parseInt(filterValue));

        // 차트 컴포넌트 데이터 샘플링 (1년 전체의 경우 렌더링 부하 방지를 위해 12시간 주기 슬라이싱)
        const sampleInterval = filterValue === 'all' ? 12 : 1;
        const sampledData = filteredData.filter((_, idx) => idx % sampleInterval === 0);

        // 상단 정보 패널 갱신
        const totalCount = filteredData.length;
        const avgUHI = filteredData.reduce((acc, d) => acc + d.uhi, 0) / totalCount;
        const avgPower = filteredData.reduce((acc, d) => acc + d.powerDemand, 0) / totalCount;

        document.getElementById('stat-count').innerText = `${totalCount.toLocaleString()} 개 타임코드`;
        document.getElementById('stat-uhi').innerText = `${avgUHI.toFixed(2)} °C`;
        document.getElementById('stat-power').innerText = `${Math.round(avgPower).toLocaleString()} MWh`;

        // --- 1. 기온 및 열섬 분석 선그래프 ---
        if (charts.temp) charts.temp.destroy();
        charts.temp = new Chart(document.getElementById('tempChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: sampledData.map(d => d.datetime),
                datasets: [
                    { label: '도심 기온 (서울) (°C)', data: sampledData.map(d => d.seoulTemp), borderColor: '#dc2626', borderWidth: 1.5, pointRadius: 0, fill: false },
                    { label: '교외 기온 (양평) (°C)', data: sampledData.map(d => d.ypTemp), borderColor: '#2563eb', borderWidth: 1.5, pointRadius: 0, fill: false },
                    { label: '열섬 강도 (서울-양평) (°C)', data: sampledData.map(d => d.uhi), borderColor: '#ea580c', borderWidth: 2, pointRadius: 0, fill: false, backgroundColor: 'rgba(234, 88, 12, 0.05)' }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top' }, tooltip: { mode: 'index', intersect: false } },
                scales: { 
                    x: { title: { display: true, text: '관측 시각' }, grid: { display: false } },
                    y: { title: { display: true, text: '기온 및 강도 (°C)' } }
                }
            }
        });

        // --- 2. 전력수요 분석 선그래프 ---
        if (charts.power) charts.power.destroy();
        charts.power = new Chart(document.getElementById('powerChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: sampledData.map(d => d.datetime),
                datasets: [{ label: '전력수요량 (MWh)', data: sampledData.map(d => d.powerDemand), borderColor: '#0d9488', borderWidth: 2, pointRadius: 0, fill: true, backgroundColor: 'rgba(13, 148, 136, 0.05)' }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top' } },
                scales: {
                    x: { title: { display: true, text: '관측 시각' }, grid: { display: false } },
                    y: { title: { display: true, text: '전력수요 (MWh)' } }
                }
            }
        });

        // --- 3. 상관관계 산점도 및 추세선 생성 ---
        const uhiList = filteredData.map(d => d.uhi);
        const powerList = filteredData.map(d => d.powerDemand);
        const r = calculatePearson(uhiList, powerList);

        document.getElementById('r-value').innerText = r.toFixed(4);

        let interpretationText = "";
        if (Math.abs(r) < 0.1) interpretationText = "상관관계가 거의 없거나 분석상 무의미합니다.";
        else if (Math.abs(r) < 0.3) interpretationText = `약한 ${r > 0 ? '양' : '음'}의 상관관계가 관찰됩니다.`;
        else if (Math.abs(r) < 0.6) interpretationText = `뚜렷한 ${r > 0 ? '양' : '음'}의 상관관계가 존재합니다.`;
        else interpretationText = `매우 강한 ${r > 0 ? '양' : '음'}의 상관관계가 실측됩니다.`;

        document.getElementById('r-interpretation').innerText = interpretationText;

        // 전체 데이터의 산점도 포인트가 너무 많을 경우 가독성을 위한 표기 포인트 필터 샘플링 적용
        const scatterSampleInterval = filterValue === 'all' ? 10 : 1;
        const scatterPoints = filteredData
            .filter((_, idx) => idx % scatterSampleInterval === 0)
            .map(d => ({ x: d.uhi, y: d.powerDemand }));

        const trendPoints = getTrendLinePoints(uhiList, powerList);

        if (charts.scatter) charts.scatter.destroy();
        charts.scatter = new Chart(document.getElementById('scatterChart').getContext('2d'), {
            data: {
                datasets: [
                    { type: 'scatter', label: '시간별 관측 지점', data: scatterPoints, backgroundColor: 'rgba(59, 130, 246, 0.6)', pointRadius: 3 },
                    { type: 'line', label: '선형 추세선', data: trendPoints, borderColor: '#ea580c', borderWidth: 2.5, pointRadius: 0, fill: false, borderDash: [6, 4] }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { type: 'linear', position: 'bottom', title: { display: true, text: '열섬 강도 (서울 기온 - 양평 기온) (°C)' } },
                    y: { title: { display: true, text: '전력수요 (MWh)' } }
                }
            }
        });

        // --- 6. 탐구 결과 동적 요약 서술부 ---
        let summaryHTML = `2025년 관측 시계열 데이터 결합 분석 결과, 선택한 탐구 영역 범위 내에서 도심(서울)과 교외(양평) 간의 **평균 열섬 강도는 ${avgUHI.toFixed(2)}°C**로 추산되었습니다.<br><br>`;
        summaryHTML += `이때 열섬 강도의 진폭과 동시간대 전력수요 지표 간의 **통계적 피어슨 상관계수(r)는 ${r.toFixed(3)}**을 기록하여 `;
        
        if (r >= 0.1) {
            summaryHTML += `**${interpretationText}** 이는 도심 내 대기 온도 가둠 현상인 열섬 강도가 증폭되는 시점에 도시 전체의 전력 에너지 소비 효율 부하(냉난방 등 기동)도 정량적 연동성을 그리며 증가하는 경향성이 있음을 내포합니다.`;
        } else if (r <= -0.1) {
            summaryHTML += `**${interpretationText}** 이는 열섬 현상의 기온 편차 추이와 전력 소비의 변동 축이 역방향으로 전개됨을 정량적으로 증명합니다.`;
        } else {
            summaryHTML += `**${interpretationText}** 실제 수집된 데이터 내에서는 열섬 강도의 단순 변화 양상 지표와 전체 통합 전력수요의 총체적 진폭 간의 규칙적인 일대일 정비례 선형 연동성은 뚜렷하게 입증되지 않는 것으로 관찰됩니다.`;
        }
        document.getElementById('summary-panel').innerHTML = summaryHTML;
    }

    // 도큐먼트 로드 완료 시 메인 초기화 기능 트리거링
    window.onload = initApp;
</script>
</body>
</html>
